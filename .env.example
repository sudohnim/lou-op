# Copy to .env and fill in values. Real env vars always take precedence over this file.

# --- inference ---
# Model for raw-api backend and LLM-as-judge calls
LOU_MODEL_ID=z-ai/glm-4.6

# OpenRouter API key (required for raw-api backend and judge)
OPENROUTER_API_KEY=sk-or-...

# Override base URL to point at a local model (e.g. Ollama)
# LOU_OPENROUTER_BASE_URL=http://localhost:11434/v1

# Optional: use a cheaper/faster model for the SLM extractor
# LOU_EXTRACTOR_MODEL_ID=

# --- agent-cli backend ---
# Which CLI agent to use: claude or codex
# LOU_AGENT_PROVIDER=claude

# Path to the agent CLI binary (if not on PATH)
# LOU_AGENT_CLI_PATH=claude

# --- job execution ---
# Where job repos are created
# LOU_JOBS_DIR=.lou-op-jobs

# Default backend when not specified in tasks.yaml
# LOU_BACKEND=mock

# Token budget for code fed to model each iteration
# LOU_CONTEXT_BUDGET=100000

# Per-iteration inference timeout (seconds)
# LOU_INFERENCE_TIMEOUT=300

# Watchdog: kill agent after N seconds of silence
# LOU_SILENCE_TIMEOUT=300
